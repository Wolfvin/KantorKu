# KantorKu Environment Variables
# Copy this file to .env and fill in your API keys

# ── LLM Provider Keys ─────────────────────────────────────
# At minimum, provide keys for the providers you use.
# See README.md for which workers use which providers.

ANTHROPIC_API_KEY=        # Conductor, coder_frontend, auditor
GOOGLE_API_KEY=           # coder_wiring, verifier_designer, scout
MINIMAX_API_KEY=          # coder_backend, verifier_engineer
DEEPSEEK_API_KEY=         # debugger, scribe, summarizer, Context Pool
OPENAI_API_KEY=           # coder_wiring (Codex)
XAI_API_KEY=              # debugger (Grok)

# ── Backend Connection ────────────────────────────────────
# URL for the Python backend (leave empty for standalone mode)
NEXT_PUBLIC_KANTORKU_BACKEND_URL=

# ── Ollama (Local) ───────────────────────────────────────
# No API key needed — runs locally at http://localhost:11434
# Workers: intake, narrator, sentinel
