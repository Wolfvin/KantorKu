# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Python ──
__pycache__/
*.py[cod]
*.pyc
*.pyo

# ── Databases (never commit binary data files) ──
*.db
*.duckdb
!.env.example

# ── Environment ──
.env
.env.*
!.env.example

# ── Rust ──
target/

# ── Node.js ──
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ──
/coverage

# ── Next.js ──
/.next/
/out/

# ── Production ──
/build

# ── Misc ──
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# ── Debug ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev.log
dev.out.log
server.log

# ── Vercel / Claude / AI ──
.vercel
.claude
.z-ai-config
local-*
test
prompt

# ── Skills ──
/skills/
